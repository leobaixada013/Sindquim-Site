# Copie para deploy/.env e substitua todos os valores antes de subir.
POSTGRES_DB=portalsindquim
POSTGRES_USER=portalsindquim
POSTGRES_PASSWORD=gere-uma-senha-longa
DIRECTUS_SECRET=gere-outro-segredo-com-no-minimo-32-bytes
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=gere-uma-senha-administrativa-longa
DIRECTUS_JURIDICO_TOKEN=gere-um-token-tecnico-longo-e-diferente
DIRECTUS_FORMS_TOKEN=gere-outro-token-tecnico-longo-e-diferente

SITE_PORT=4421
DIRECTUS_PORT=8155
PUBLIC_SITE_URL=http://localhost:4421
PUBLIC_DIRECTUS_URL=http://localhost:8155
PORTAL_DEMO=true

# Configure SMTP real antes de convidar usuários ou responder chamados.
EMAIL_TRANSPORT=smtp
EMAIL_FROM=no-reply@exemplo.invalid
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
