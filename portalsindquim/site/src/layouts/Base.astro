---
import '@fontsource-variable/archivo';
import '@fontsource-variable/source-serif-4';
import '../styles/global.css';
import { InstagramLogoIcon, MagnifyingGlassIcon, YoutubeLogoIcon } from '@phosphor-icons/react/ssr';
import { getConfiguracoes, getConfiguracoesGlobais, urlArquivo } from '../lib/directus';
import { DESCRICAO_PADRAO, MENU, NOME_CURTO, NOME_SITE, SUBTITULO_MARCA } from '../lib/constantes';

interface Props {
  titulo?: string;
  descricao?: string;
  imagemOg?: string | null;
  tipoOg?: string;
}

const { titulo, descricao = DESCRICAO_PADRAO, imagemOg, tipoOg = 'website' } = Astro.props;
const tituloFinal = titulo ? `${titulo} — ${NOME_CURTO}` : NOME_SITE;
const [config, globais] = await Promise.all([getConfiguracoes(), getConfiguracoesGlobais()]);
const urlCanonica = new URL(Astro.url.pathname, Astro.site);
const caminhoAtual = Astro.url.pathname.replace(/\/$/, '') || '/';
const linkWhatsapp = config?.whatsapp ? `https://wa.me/${config.whatsapp.replace(/\D/g, '')}` : null;
const moduloJuridicoAtivo = globais.modulo_juridico_ativo !== false;
const moduloYoutubeAtivo = config?.podcast_ativo === true || globais.modulo_youtube_ativo === true;
const ambienteDemonstracao = String(process.env.PORTAL_DEMO ?? import.meta.env.PORTAL_DEMO ?? '').toLowerCase() === 'true';
const logoSite = urlArquivo(globais.logo_site) ?? '/logo-sindicato.jpeg';
const termoBusca = Astro.url.pathname === '/buscar' ? Astro.url.searchParams.get('q')?.trim() ?? '' : '';
const menuVisivel = MENU.filter((item) => {
  if (item.href === '/juridico') return moduloJuridicoAtivo;
  if (item.href === '/#videos') return moduloYoutubeAtivo;
  return true;
});
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloFinal}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={urlCanonica} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`Notícias — ${NOME_CURTO}`} href="/rss.xml" />
    <meta property="og:title" content={tituloFinal} />
    <meta property="og:description" content={descricao} />
    <meta property="og:type" content={tipoOg} />
    <meta property="og:url" content={urlCanonica} />
    <meta property="og:site_name" content={NOME_SITE} />
    <meta property="og:locale" content="pt_BR" />
    {imagemOg && <meta property="og:image" content={imagemOg} />}
    <meta name="twitter:card" content={imagemOg ? 'summary_large_image' : 'summary'} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Ir para o conteúdo</a>

    {ambienteDemonstracao && (
      <aside class="demo-banner" role="note">
        <strong>Validação institucional pendente.</strong> Algumas informações de benefícios, jurídico e contato ainda precisam ser confirmadas pelo sindicato.
      </aside>
    )}

    <div class="topbar">
      <div class="container topbar__inner">
        <a class="brand brand--topbar" href="/" aria-label={`${NOME_CURTO}, página inicial`}>
          <img class="brand__logo" src={logoSite} alt="" width="42" height="42" />
          <span class="brand__nome">{NOME_CURTO}<small>{SUBTITULO_MARCA}</small></span>
        </a>

        <form class="site-search" role="search" method="get" action="/buscar">
          <label class="sr-only" for="busca-global">Buscar no site</label>
          <input
            id="busca-global"
            type="search"
            name="q"
            value={termoBusca}
            minlength="2"
            maxlength="100"
            placeholder="Buscar notícias e serviços"
          />
          <button type="submit" aria-label="Buscar">
            <MagnifyingGlassIcon size={20} weight="bold" aria-hidden="true" />
          </button>
        </form>

        <div class="topbar__aside">
          {(config?.telefone || config?.email || linkWhatsapp) && (
            <div class="topbar__links topbar__contatos">
              {config?.telefone && (
                <a href={`tel:+55${config.telefone.replace(/\D/g, '')}`}>{config.telefone}</a>
              )}
              {config?.email && <a href={`mailto:${config.email}`}>{config.email}</a>}
              {linkWhatsapp && <a href={linkWhatsapp} target="_blank" rel="noopener">WhatsApp</a>}
            </div>
          )}
          <nav class="social-links" aria-label="Redes sociais">
            <span>Acompanhe pelas redes</span>
            {config?.instagram_url && (
              <a class="social-links__instagram" href={config.instagram_url} target="_blank" rel="noopener" aria-label="Instagram" title="Instagram">
                <InstagramLogoIcon size={23} aria-hidden="true" />
              </a>
            )}
            {moduloYoutubeAtivo && config?.youtube_url && (
              <a class="social-links__youtube" href={config.youtube_url} target="_blank" rel="noopener" aria-label="YouTube" title="YouTube">
                <YoutubeLogoIcon size={23} aria-hidden="true" />
              </a>
            )}
          </nav>
        </div>
      </div>
    </div>

    <header class="mainnav">
      <div class="container mainnav__inner">
        <nav aria-label="Menu principal">
          <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="menu-principal">
            Menu
          </button>
          <ul class="menu" id="menu-principal">
            {menuVisivel.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={caminhoAtual === item.href ? 'page' : undefined}
                >
                  {item.rotulo}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="conteudo">
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__grid">
          <div>
            <h3>{NOME_CURTO}</h3>
            <p>{NOME_SITE}. Representação, negociação coletiva e defesa dos direitos da categoria.</p>
            {config?.endereco && <p>{config.endereco}</p>}
          </div>
          <div>
            <h3>Institucional</h3>
            <ul>
              <li><a href="/diretoria">Diretoria</a></li>
              <li><a href="/beneficios">Benefícios</a></li>
              {moduloJuridicoAtivo && <li><a href="/juridico">Jurídico</a></li>}
              <li><a href="/filie-se">Filie-se</a></li>
              <li><a href="/contato">Contato</a></li>
            </ul>
          </div>
          <div>
            <h3>Conteúdo</h3>
            <ul>
              <li><a href="/noticias">Notícias</a></li>
              <li><a href="/beneficios">Benefícios</a></li>
              {moduloJuridicoAtivo && <li><a href="/juridico">Jurídico</a></li>}
              <li><a href="/rss.xml">Feed RSS</a></li>
            </ul>
          </div>
        </div>
        <div class="footer__bottom">
          <span>© {new Date().getFullYear()} {NOME_SITE}</span>
          <span>Feito pelo sindicato, para a categoria.</span>
        </div>
      </div>
    </footer>

    <script>
      const botao = document.querySelector('.menu-toggle');
      const menu = document.getElementById('menu-principal');
      if (botao && menu && window.matchMedia('(max-width: 820px)').matches) {
        menu.hidden = true;
        botao.addEventListener('click', () => {
          const aberto = botao.getAttribute('aria-expanded') === 'true';
          botao.setAttribute('aria-expanded', String(!aberto));
          menu.hidden = aberto;
        });
      }

      const revelar = document.querySelectorAll('.reveal');
      if (revelar.length > 0 && 'IntersectionObserver' in window) {
        const observador = new IntersectionObserver(
          (entradas) => {
            for (const entrada of entradas) {
              if (entrada.isIntersecting) {
                entrada.target.classList.add('reveal--visivel');
                observador.unobserve(entrada.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' },
        );
        revelar.forEach((el) => observador.observe(el));
      }
    </script>
  </body>
</html>
