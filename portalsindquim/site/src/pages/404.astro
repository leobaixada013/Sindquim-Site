---
import Base from '../layouts/Base.astro';

Astro.response.status = 404;
---

<Base titulo="Página não encontrada">
  <section class="section">
    <div class="container" style="text-align:center;padding:60px 20px">
      <p class="rotulo" style="justify-content:center">Erro 404</p>
      <h1>Página não encontrada</h1>
      <p style="max-width:32rem;margin:0 auto 24px;color:var(--texto-suave)">
        O endereço pode ter mudado ou a página foi removida. Use o menu ou volte para o início.
      </p>
      <a class="button button--tinta" href="/">Voltar ao início</a>
    </div>
  </section>
</Base>
