---
import Base from '../layouts/Base.astro';
import {
  getConfiguracoesGlobais,
  getJuridicoDireitos,
  getJuridicoFAQ,
  getJuridicoPlantoes,
  getPaginaJuridico,
} from '../lib/directus';
const estado = Astro.url.searchParams.get('agendamento');
const estadoChamado = Astro.url.searchParams.get('chamado');
const globais = await getConfiguracoesGlobais();
if (globais.modulo_juridico_ativo === false) {
  return Astro.redirect('/');
}

const [pagina, direitos, plantoes, faq] = await Promise.all([
  getPaginaJuridico(),
  getJuridicoDireitos(),
  getJuridicoPlantoes(),
  getJuridicoFAQ(),
]);
---

<Base titulo="Jurídico" descricao={pagina.seo_descricao ?? 'Atendimento jurídico do sindicato para orientação e defesa dos direitos trabalhistas.'}>
  <section class="hero reveal" aria-labelledby="juridico-hero-titulo">
    <div class="hero__media juridico-hero__media" aria-hidden="true"></div>
    <div class="container hero__content">
      <div class="hero__copy">
        <p class="rotulo rotulo--claro">{pagina.hero_rotulo}</p>
        <h1 id="juridico-hero-titulo">{pagina.hero_titulo}</h1>
        <p class="hero__resumo">{pagina.hero_resumo}</p>
        <div class="hero__actions">
          <a class="button button--primario" href={pagina.hero_cta_primario_href || '#agendamento'}>{pagina.hero_cta_primario_texto}</a>
          <a class="button button--fantasma" href={pagina.hero_cta_secundario_href || '#direitos'}>{pagina.hero_cta_secundario_texto}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section reveal" id="direitos" aria-labelledby="direitos-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">{pagina.direitos_rotulo}</p>
          <h2 id="direitos-titulo">{pagina.direitos_titulo}</h2>
        </div>
      </div>

      <div class="direitos-grid">
        {direitos.map((direito) => (
          <article class:list={[
            'direito-card',
            direito.destaque && 'direito-card--largo',
            direito.cor === 'vermelho' ? 'direito-card--vermelho' : 'direito-card--aco',
          ]}>
            {direito.urgente && <span class="tag tag--urgente">Urgente</span>}
            <span class="direito-card__icone" aria-hidden="true">{direito.sigla}</span>
            <h3>{direito.titulo}</h3>
            <p>{direito.descricao}</p>
            <a class="text-link" href="#agendamento" aria-label={`Ler detalhes sobre ${direito.titulo}`}>
              {direito.texto_link || 'Ler detalhes'}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cinza reveal" id="agendamento" aria-labelledby="agendamento-titulo">
    <div class="container juridico-agenda">
      <div class="juridico-agenda__intro">
        <p class="rotulo">{pagina.agendamento_rotulo}</p>
        <h2 id="agendamento-titulo">{pagina.agendamento_titulo}</h2>
        <div class="prosa">
          <p>{pagina.agendamento_texto}</p>
        </div>

        {plantoes.map((plantao) => (
          <aside class="juridico-plantao" aria-label={plantao.titulo}>
            <h3 class="juridico-plantao__titulo">{plantao.titulo || pagina.plantao_titulo}</h3>
            <dl class="juridico-plantao__lista">
              <dt>Local</dt>
              <dd>{plantao.local}</dd>
              <dt>Horário</dt>
              <dd>{plantao.horario}</dd>
              {plantao.observacao && (
                <>
                  <dt>Observação</dt>
                  <dd>{plantao.observacao}</dd>
                </>
              )}
            </dl>
          </aside>
        ))}
      </div>

      <div class="juridico-agenda__form-wrap chamado-card">
        {estado === 'ok' && (
          <p class="form-ok" role="status">Agendamento enviado. Entraremos em contato em até 2 dias úteis.</p>
        )}
        {estado === 'erro' && (
          <p class="form-erro" role="alert">Não foi possível enviar. Tente novamente ou ligue para a sede.</p>
        )}
        {estadoChamado === 'ok' && (
          <p class="form-ok" role="status">Triagem enviada com segurança. {pagina.chamado_prazo_texto}</p>
        )}
        {estadoChamado === 'erro' && (
          <p class="form-erro" role="alert">Não foi possível abrir o chamado. Revise os campos e o anexo e tente novamente.</p>
        )}
        {estadoChamado === 'limite' && (
          <p class="form-erro" role="alert">Houve muitas tentativas em pouco tempo. Aguarde alguns minutos antes de enviar novamente.</p>
        )}

        <div class="chamado-card__intro">
          <span class="tag">Triagem protegida</span>
          <h3>{pagina.chamado_titulo}</h3>
          <p>{pagina.chamado_resumo}</p>
        </div>

        <form class="form-grid juridico-agenda__form chamado-form" method="POST" action="/api/juridico" enctype="multipart/form-data">
          <label>
            Nome completo
            <input type="text" name="nome" required maxlength="120" autocomplete="name" placeholder="Seu nome completo" />
          </label>
          <label>
            CPF <small>(opcional na primeira triagem)</small>
            <input type="text" name="cpf" required={pagina.chamado_exigir_cpf === true} maxlength="14" inputmode="numeric" autocomplete="off" placeholder="000.000.000-00" />
          </label>
          <label>
            E-mail
            <input type="email" name="email" required maxlength="180" autocomplete="email" placeholder="voce@email.com" />
          </label>
          <label>
            Telefone
            <input type="tel" name="telefone" required maxlength="40" autocomplete="tel" placeholder="(00) 00000-0000" />
          </label>
          <label class="form-grid__full">
            Tipo de demanda
            <select name="tipo" required>
              <option value="" disabled selected>Selecione o assunto principal</option>
              <option value="Demissão / Rescisão">Demissão / Rescisão</option>
              <option value="Horas Extras / Jornada">Horas Extras / Jornada</option>
              <option value="Assédio / Discriminação">Assédio / Discriminação</option>
              <option value="Acidente de Trabalho">Acidente de Trabalho</option>
              <option value="Dúvida Geral">Dúvida Geral</option>
            </select>
          </label>
          <label class="form-grid__full">
            Descrição do caso
            <textarea name="descricao" rows="6" required maxlength="5000" placeholder="Conte o que aconteceu, datas relevantes, empresa envolvida e qual orientação você precisa."></textarea>
          </label>
          <label class="form-grid__full chamado-upload">
            Documento de apoio <small>{pagina.chamado_exigir_anexo === true ? '(obrigatório)' : '(opcional)'}</small>
            <input type="file" name="anexo" required={pagina.chamado_exigir_anexo === true} accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/jpeg,image/png,image/webp" />
            <small>Envie PDF ou imagem com até 10 MB somente quando isso ajudar a explicar o caso. Não inclua documentos de terceiros sem autorização.</small>
          </label>
          <div class="form-grid__full chamado-lgpd" id="aviso-privacidade">
            <strong>Aviso de privacidade</strong>
            <p>{pagina.chamado_privacidade_texto}</p>
            <label class="chamado-consentimento">
              <input type="checkbox" name="consentimento_privacidade" value="sim" required />
              Li o aviso e concordo com o uso desses dados para a triagem jurídica.
            </label>
          </div>
          <label class="campo-honeypot" aria-hidden="true">
            Não preencha <input type="text" name="site" tabindex="-1" autocomplete="off" />
          </label>
          <button class="button button--primario" type="submit">Abrir chamado jurídico</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section reveal" aria-labelledby="faq-titulo">
    <div class="container container--estreito">
      <div class="section-heading">
        <div>
          <p class="rotulo">{pagina.faq_rotulo}</p>
          <h2 id="faq-titulo">{pagina.faq_titulo}</h2>
        </div>
      </div>

      <div class="faq-lista">
        {faq.map((item) => (
          <details class="faq-item">
            <summary class="faq-item__pergunta">{item.pergunta}</summary>
            <div class="faq-item__resposta prosa">
              <p>{item.resposta}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band reveal">
    <div class="container cta-band__inner">
      <div>
        <p class="rotulo">{pagina.cta_rotulo}</p>
        <h2>{pagina.cta_titulo}</h2>
      </div>
      <a class="button" href={pagina.cta_link_href || '/filie-se'}>{pagina.cta_link_texto}</a>
    </div>
  </section>
</Base>

<style>
  .chamado-card {
    position: relative;
    overflow: hidden;
    padding: clamp(20px, 3vw, 28px);
    border: 1px solid rgba(69, 128, 172, 0.18);
    border-radius: 28px;
    background:
      radial-gradient(circle at 8% 0%, rgba(69, 128, 172, 0.14), transparent 36%),
      radial-gradient(circle at 92% 12%, rgba(231, 58, 63, 0.08), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(245, 248, 252, 0.94));
    box-shadow: 0 18px 48px rgba(9, 20, 38, 0.12);
  }

  .chamado-card__intro {
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(69, 128, 172, 0.14);
  }

  .chamado-card__intro h3 {
    margin: 12px 0 8px;
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    letter-spacing: -0.04em;
  }

  .chamado-card__intro p {
    margin: 0;
    color: var(--texto-suave);
    line-height: 1.6;
  }

  .chamado-form {
    padding: 0;
    background: transparent;
    box-shadow: none;
  }

  .chamado-form select,
  .chamado-form input[type='file'] {
    width: 100%;
  }

  .chamado-upload small,
  .chamado-lgpd {
    color: var(--texto-suave);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .chamado-lgpd {
    margin: 0;
    padding: 14px 16px;
    border: 1px solid rgba(69, 128, 172, 0.18);
    border-radius: 18px;
    background: rgba(69, 128, 172, 0.08);
  }
</style>
