---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminUser, tokenAdmin, usuarioAdminSistema } from '../../lib/auth';

const token = tokenAdmin(Astro.cookies);
if (!token) return Astro.redirect('/admin/login');
const usuario = await getAdminUser(Astro.cookies);
if (!usuario) return Astro.redirect('/admin/login?erro=sessao');

const directus = (process.env.PUBLIC_DIRECTUS_URL ?? import.meta.env.PUBLIC_DIRECTUS_URL ?? 'http://localhost:8055').replace(/\/$/, '');
const role = typeof usuario.role === 'object' && usuario.role ? String(usuario.role.name ?? '') : '';
const admin = usuarioAdminSistema(usuario);
const editor = admin || role === 'Editor';
const juridico = admin || /jur[ií]dico/i.test(role);

const tarefas = [
  {
    mostrar: editor,
    href: '/admin/noticias/novo',
    titulo: 'Criar uma notícia',
    texto: 'Adicione título, foto de capa e texto. A notícia começa como rascunho.',
    acao: 'Começar agora',
    destaque: true,
  },
  {
    mostrar: editor,
    href: '/admin/noticias',
    titulo: 'Revisar notícias',
    texto: 'Continue um rascunho, agende uma publicação ou corrija uma matéria.',
    acao: 'Ver notícias',
  },
  {
    mostrar: editor,
    href: '/admin/podcast',
    titulo: 'Atualizar o podcast',
    texto: 'Confira o canal e anuncie o próximo episódio com data e arte.',
    acao: 'Abrir podcast',
  },
  {
    mostrar: editor,
    href: `${directus}/admin/content/beneficios`,
    titulo: 'Atualizar benefícios',
    texto: 'Cadastre vantagens, regras, validade e instruções para o associado.',
    acao: 'Abrir benefícios',
  },
  {
    mostrar: editor,
    href: `${directus}/admin/content/diretores`,
    titulo: 'Atualizar a diretoria',
    texto: 'Cadastre nomes, funções e fotos e escolha a ordem em que aparecem no site.',
    acao: 'Abrir diretoria',
  },
  {
    mostrar: editor,
    href: `${directus}/admin/content/pagina_juridico`,
    titulo: 'Editar a página Jurídico',
    texto: 'Altere textos e chamadas públicas sem mexer na triagem protegida.',
    acao: 'Editar conteúdo público',
  },
  {
    mostrar: juridico,
    href: '/admin/juridico',
    titulo: 'Atender solicitações jurídicas',
    texto: 'Veja chamados, anexos autorizados e registre respostas da equipe.',
    acao: 'Abrir atendimentos',
  },
  {
    mostrar: admin,
    href: '/admin/settings?aba=usuarios',
    titulo: 'Cadastrar pessoas',
    texto: 'Convide editores ou integrantes do Jurídico com acesso limitado.',
    acao: 'Gerenciar acessos',
  },
].filter((tarefa) => tarefa.mostrar);
---

<AdminLayout
  titulo="O que você quer fazer?"
  subtitulo="Escolha uma tarefa. Cada tela mostra somente o necessário para concluí-la."
>
  <div slot="actions">
    <a class="admin-button" href="/" target="_blank" rel="noopener">Ver o site</a>
  </div>

  {tarefas.length > 0 ? (
    <section class="task-grid" aria-label="Tarefas disponíveis">
      {tarefas.map((tarefa, indice) => (
        <article class:list={['admin-panel', 'task-card', tarefa.destaque && 'task-card--featured']}>
          <span class="task-card__number" aria-hidden="true">{String(indice + 1).padStart(2, '0')}</span>
          <h2>{tarefa.titulo}</h2>
          <p class="admin-muted">{tarefa.texto}</p>
          <a class:list={['admin-button', tarefa.destaque && 'admin-button--primary']} href={tarefa.href}>{tarefa.acao}</a>
        </article>
      ))}
    </section>
  ) : (
    <section class="admin-panel">
      <h2>Sua conta ainda não tem uma área definida</h2>
      <p class="admin-muted">Peça a um administrador para atribuir a função Editor ou Jurídico.</p>
    </section>
  )}

  <aside class="admin-panel editorial-help">
    <div>
      <span class="admin-chip">Publicação simples</span>
      <h2>Para publicar uma notícia</h2>
    </div>
    <ol>
      <li>Escreva o título e o texto.</li>
      <li>Escolha a capa e, se quiser, outras fotos.</li>
      <li>Informe a fonte da notícia.</li>
      <li>Use “Salvar rascunho”, “Agendar” ou “Publicar agora”.</li>
    </ol>
  </aside>
</AdminLayout>

<style>
  .task-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .task-card {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    align-items: flex-start;
  }

  .task-card--featured {
    border-color: rgba(107, 182, 234, .48);
    background: linear-gradient(145deg, rgba(69, 128, 172, .2), rgba(255, 255, 255, .05));
  }

  .task-card__number {
    color: var(--admin-primary);
    font-size: .78rem;
    font-weight: 900;
    letter-spacing: .12em;
  }

  .task-card h2 { margin: 18px 0 10px; }
  .task-card p { flex: 1; }

  .editorial-help {
    display: grid;
    grid-template-columns: minmax(220px, .7fr) minmax(0, 1.3fr);
    gap: 30px;
    margin-top: 22px;
  }

  .editorial-help ol {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 24px;
  }

  @media (max-width: 980px) {
    .task-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 680px) {
    .task-grid,
    .editorial-help { grid-template-columns: 1fr; }
    .task-card { min-height: 220px; }
  }
</style>
