---
import {
  EnvelopeSimpleIcon,
  HeadsetIcon,
  MapPinIcon,
  PhoneCallIcon,
  WhatsappLogoIcon,
} from '@phosphor-icons/react/ssr';
import Base from '../layouts/Base.astro';
import { getConfiguracoes } from '../lib/directus';

const config = await getConfiguracoes();

function numeroBrasil(numero: string | null | undefined) {
  const digitos = numero?.replace(/\D/g, '') ?? '';
  if (!digitos) return null;
  return digitos.startsWith('55') && digitos.length >= 12 ? digitos : `55${digitos}`;
}

const telefone = numeroBrasil(config?.telefone);
const whatsapp = numeroBrasil(config?.whatsapp);
const linkWhatsapp = whatsapp
  ? `https://wa.me/${whatsapp}?text=${encodeURIComponent('Olá! Gostaria de falar com o Sindquim.')}`
  : null;
const buscaEndereco = config?.endereco ? encodeURIComponent(config.endereco) : null;
const linkMapa = buscaEndereco ? `https://www.google.com/maps/search/?api=1&query=${buscaEndereco}` : null;
const mapaEmbed = buscaEndereco ? `https://www.google.com/maps?q=${buscaEndereco}&output=embed` : null;
---

<Base titulo="Contato" descricao="Telefone, e-mail, WhatsApp e endereço do Sindicato dos Químicos da Baixada Santista.">
  <section class="section contact-page">
    <div class="container">
      <header class="contact-hero">
        <p class="contact-hero__eyebrow">
          <HeadsetIcon size={24} weight="duotone" aria-hidden="true" />
          <span>Atendimento</span>
        </p>
        <h1>Fale com o sindicato</h1>
        <p>Escolha o canal mais simples para você. Estamos aqui para orientar e ajudar.</p>
      </header>

      <div class="contact-channels" aria-label="Canais de atendimento">
        {config?.telefone && telefone && (
          <a class="contact-card contact-card--phone" href={`tel:+${telefone}`}>
            <span class="contact-card__icon" aria-hidden="true">
              <PhoneCallIcon size={30} weight="duotone" />
            </span>
            <span class="contact-card__content">
              <small>Telefone</small>
              <strong>{config.telefone}</strong>
              <span>Toque para ligar</span>
            </span>
          </a>
        )}

        {config?.email && (
          <a class="contact-card contact-card--email" href={`mailto:${config.email}`}>
            <span class="contact-card__icon" aria-hidden="true">
              <EnvelopeSimpleIcon size={30} weight="duotone" />
            </span>
            <span class="contact-card__content">
              <small>E-mail</small>
              <strong>{config.email}</strong>
              <span>Toque para escrever</span>
            </span>
          </a>
        )}
      </div>

      {linkWhatsapp && (
        <div class="contact-whatsapp">
          <div>
            <span class="contact-whatsapp__icon" aria-hidden="true">
              <WhatsappLogoIcon size={34} weight="fill" />
            </span>
            <span>
              <strong>Prefere conversar por mensagem?</strong>
              <small>Abra uma conversa direta com o atendimento do sindicato.</small>
            </span>
          </div>
          <a class="button button--whatsapp" href={linkWhatsapp} target="_blank" rel="noopener">
            <WhatsappLogoIcon size={23} weight="fill" aria-hidden="true" />
            Enviar mensagem no WhatsApp
          </a>
        </div>
      )}

      {config?.endereco && mapaEmbed && linkMapa && (
        <section class="contact-location" aria-labelledby="titulo-localizacao">
          <div class="contact-location__details">
            <span class="contact-location__icon" aria-hidden="true">
              <MapPinIcon size={30} weight="duotone" />
            </span>
            <div>
              <p class="rotulo">Onde estamos</p>
              <h2 id="titulo-localizacao">Sede do Sindquim</h2>
              <address>{config.endereco}</address>
              <a class="text-link" href={linkMapa} target="_blank" rel="noopener">Abrir rota no Google Maps</a>
            </div>
          </div>
          <div class="contact-location__map">
            <iframe
              src={mapaEmbed}
              title={`Mapa da sede do Sindquim: ${config.endereco}`}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )}
    </div>
  </section>
</Base>
