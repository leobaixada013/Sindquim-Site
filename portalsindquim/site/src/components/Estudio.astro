---
import 'lite-youtube-embed/src/lite-yt-embed.css';
import { getConfiguracoes, getConfiguracoesGlobais, getProximosVideos, urlImagem } from '../lib/directus';
import { formatarDataEstreia } from '../lib/formatar';
import { getVideosYoutube } from '../lib/youtube';

const [config, globais, proximos, videos] = await Promise.all([
  getConfiguracoes(),
  getConfiguracoesGlobais(),
  getProximosVideos(),
  getVideosYoutube(6),
]);

const youtubeAtivo = globais.modulo_youtube_ativo === true;
const canalUrl = youtubeAtivo ? config?.youtube_url ?? null : null;
const proximosVisiveis = youtubeAtivo ? proximos : [];
const destaque = videos[0] ?? null;
const recentes = videos.slice(1, 6);
const temConteudo = proximosVisiveis.length > 0 || destaque !== null;
---

{(temConteudo || canalUrl) && (
  <section id="videos" class="section estudio reveal" aria-labelledby="estudio-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo rotulo--claro">Áudio e vídeo</p>
          <h2 id="estudio-titulo">Canal do sindicato</h2>
        </div>
        {canalUrl && (
          <a class="button button--fantasma" href={canalUrl} target="_blank" rel="noopener">
            Inscreva-se no canal
          </a>
        )}
      </div>

      {temConteudo ? (
        <div class="estudio__layout">
          <div>
            {destaque ? (
              <>
                <div class="estudio__player">
                  <lite-youtube
                    videoid={destaque.videoId}
                    playlabel={`Assistir: ${destaque.titulo}`}
                    style={`background-image:url('${destaque.thumbnailUrl}')`}
                  ></lite-youtube>
                </div>
                <p class="estudio__player-titulo">{destaque.titulo}</p>
              </>
            ) : (
              proximosVisiveis[0] && (
                <article
                  class:list={['proximo-video', proximosVisiveis[0].imagem && 'proximo-video--com-imagem']}
                  style={proximosVisiveis[0].imagem ? `background-image:url('${urlImagem(proximosVisiveis[0].imagem, { largura: 900, altura: 520 })}')` : undefined}
                >
                  <span class="chip-estreia">Próximo vídeo</span>
                  <h3>{proximosVisiveis[0].titulo}</h3>
                  {proximosVisiveis[0].descricao && <p>{proximosVisiveis[0].descricao}</p>}
                  <span class="proximo-video__quando">{formatarDataEstreia(proximosVisiveis[0].data_estreia)}</span>
                </article>
              )
            )}
          </div>

          <div class="estudio__rail">
            {destaque !== null &&
              proximosVisiveis.map((anuncio) => (
                <article
                  class:list={['proximo-video', anuncio.imagem && 'proximo-video--com-imagem']}
                  style={anuncio.imagem ? `background-image:url('${urlImagem(anuncio.imagem, { largura: 640, altura: 400 })}')` : undefined}
                >
                  <span class="chip-estreia">Próximo vídeo</span>
                  <h3>{anuncio.titulo}</h3>
                  {anuncio.descricao && <p>{anuncio.descricao}</p>}
                  <span class="proximo-video__quando">{formatarDataEstreia(anuncio.data_estreia)}</span>
                </article>
              ))}

            {recentes.length > 0 && (
              <div class="video-lista">
                <p class="video-lista__titulo">Vídeos recentes</p>
                {recentes.map((video) => (
                  <a class="video-item" href={video.link} target="_blank" rel="noopener">
                    <img src={video.thumbnailUrl} alt="" loading="lazy" decoding="async" width="116" height="65" />
                    <span>{video.titulo}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ) : (
        <p>
          Em breve, novos vídeos no canal do sindicato.{' '}
          <a class="text-link" href={canalUrl} target="_blank" rel="noopener">Acesse o canal</a>.
        </p>
      )}
    </div>
  </section>
)}

<script>
  import 'lite-youtube-embed';
</script>
