{
  "name": "portalsindquim-site",
  "type": "module",
  "version": "1.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "typecheck": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:ci": "npm run check && npm test && npm run build",
    "test:docker": "vitest run --exclude src/lib/operacao-docker.test.mjs",
    "test:local": "vitest run --exclude src/lib/deploy-lxc200.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-android --project=mobile-iphone --project=mobile-compact-320",
    "test:e2e:report": "playwright show-report",
    "playwright:install": "playwright install chromium webkit"
  },
  "dependencies": {
    "@astrojs/node": "11.0.2",
    "@astrojs/react": "5.0.7",
    "@astrojs/rss": "4.0.19",
    "@astryxdesign/core": "0.1.4",
    "@astryxdesign/theme-neutral": "0.1.4",
    "@directus/sdk": "23.0.0",
    "@fontsource-variable/archivo": "5.3.0",
    "@fontsource-variable/source-serif-4": "5.3.0",
    "@types/nodemailer": "8.0.1",
    "astro": "7.1.3",
    "fast-xml-parser": "5.10.1",
    "isomorphic-dompurify": "3.19.0",
    "lite-youtube-embed": "0.3.4",
    "nodemailer": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astryxdesign/cli": "0.1.4",
    "@playwright/test": "^1.61.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
