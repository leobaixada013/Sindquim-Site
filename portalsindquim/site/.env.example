# Copie para .env e preencha antes de subir.
# Gere o SECRET com: openssl rand -hex 32
DIRECTUS_SECRET=
DIRECTUS_ADMIN_EMAIL=
DIRECTUS_ADMIN_PASSWORD=

# URLs públicas (em teste na LAN use os IP:porta; em produção os domínios do tunnel)
PUBLIC_SITE_URL=http://192.168.31.146:4321
PUBLIC_DIRECTUS_URL=http://192.168.31.146:8055

# SMTP para envio de respostas do módulo jurídico
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Jurídico Sindicato <juridico@example.org>"
SMTP_REPLY_TO=
