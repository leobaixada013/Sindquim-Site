---
import Base from '../layouts/Base.astro';
import { getDocumentos, urlArquivo } from '../lib/directus';

const documentos = await getDocumentos();
const rotuloTipo: Record<string, string> = {
  convencao: 'Convenção',
  acordo: 'Acordo',
  ata: 'Ata',
  edital: 'Edital',
  outro: 'Documento',
};
---

<Base titulo="Convenções e documentos" descricao="Convenções coletivas, acordos, atas e editais do sindicato.">
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">Transparência</p>
          <h1>Convenções e documentos</h1>
        </div>
      </div>

      {documentos.length > 0 ? (
        <table class="doc-tabela">
          <thead>
            <tr>
              <th>Documento</th>
              <th>Tipo</th>
              <th>Ano</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {documentos.map((doc) => (
              <tr>
                <td>{doc.titulo}</td>
                <td><span class="tag">{rotuloTipo[doc.tipo] ?? 'Documento'}</span></td>
                <td>{doc.ano ?? '—'}</td>
                <td>
                  {doc.arquivo ? (
                    <a class="text-link" href={urlArquivo(doc.arquivo)} target="_blank" rel="noopener">
                      Baixar PDF
                    </a>
                  ) : (
                    <span style="color:var(--texto-suave)">Em breve</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="vazio">Os documentos publicados no painel aparecem aqui.</p>
      )}
    </div>
  </section>
</Base>
