---
import Base from '../layouts/Base.astro';
import { getPagina } from '../lib/directus';

const { slug } = Astro.params;
const pagina = slug ? await getPagina(slug) : null;
if (!pagina) {
  return Astro.rewrite('/404');
}
---

<Base titulo={pagina.titulo}>
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">Sindicato</p>
          <h1>{pagina.titulo}</h1>
        </div>
      </div>
      <div class="prosa" set:html={pagina.conteudo ?? ''} />
    </div>
  </section>
</Base>
