п»ҝ---
import Base from '../layouts/Base.astro';
import NoticiaCard from '../components/NoticiaCard.astro';
import Estudio from '../components/Estudio.astro';
import VitrineSocial from '../components/VitrineSocial.astro';
import {
  getAvisoUrgente,
  getAvisosRapidos,
  getConfiguracoesGlobais,
  getPostBanner,
  getPosts,
  urlImagem,
} from '../lib/directus';
import { formatarData, formatarDiaMes } from '../lib/formatar';

const [banner, todosPosts, avisoUrgente, avisosRapidos, globais] = await Promise.all([
  getPostBanner(),
  getPosts(6),
  getAvisoUrgente(),
  getAvisosRapidos(4),
  getConfiguracoesGlobais(),
]);

const postsSemBanner = todosPosts.filter((post) => post.id !== banner?.id);
const noticiaDestaque = postsSemBanner[0] ?? null;
const noticiasGrade = postsSemBanner.slice(1, 4);
const temAvisos = avisosRapidos.length > 0;
const imagemBanner = banner ? urlImagem(banner.imagem, { largura: 1600, altura: 900 }) : null;
---

<Base imagemOg={imagemBanner}>
  {avisoUrgente && (
    <aside class="alert-strip" aria-label="Aviso urgente">
      <div class="container alert-strip__inner">
        <strong>{avisoUrgente.titulo}</strong>
        {avisoUrgente.mensagem_curta && <span>{avisoUrgente.mensagem_curta}</span>}
        {avisoUrgente.link && (
          <a href={avisoUrgente.link}>{avisoUrgente.texto_link ?? 'Saiba mais'}</a>
        )}
      </div>
    </aside>
  )}

  <section class="hero" aria-labelledby="hero-titulo">
    <div class="hero__media" style={imagemBanner ? `background-image:url('${imagemBanner}')` : undefined} aria-hidden="true"></div>
    {banner?.fixado_banner && <span class="carimbo" aria-hidden="true">Fixado pela diretoria</span>}
    <div class="container hero__content">
      <div class="hero__copy">
        {banner ? (
          <>
            <div class="hero__meta">
              {banner.categoria && <strong>{banner.categoria.nome}</strong>}
              <time datetime={banner.date_created}>{formatarData(banner.date_created)}</time>
            </div>
            <h1 id="hero-titulo">{banner.titulo}</h1>
            {banner.resumo && <p class="hero__resumo">{banner.resumo}</p>}
            <div class="hero__actions">
              <a class="button button--primario" href={`/noticias/${banner.slug}`}>Ler matГғВ©ria completa</a>
              <a class="button button--fantasma" href="/noticias">Todas as notГғВӯcias</a>
            </div>
          </>
        ) : (
          <>
            <p class="rotulo rotulo--claro">InformaГғВ§ГғВЈo oficial</p>
            <h1 id="hero-titulo">Nosso trabalho tem valor. Nossos direitos nГғВЈo sГғВЈo negociГғВЎveis.</h1>
            <p class="hero__resumo">
              NotГғВӯcias, mobilizaГғВ§ГғВЈo e atendimento para fortalecer a categoria em cada negociaГғВ§ГғВЈo.
            </p>
            <div class="hero__actions">
              <a class="button button--primario" href="/noticias">Ver notГғВӯcias</a>
              <a class="button button--fantasma" href="/filie-se">Filie-se</a>
            </div>
          </>
        )}
      </div>
    </div>
  </section>


  <section id="noticias" class="section reveal" aria-labelledby="noticias-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">Boletim da categoria</p>
          <h2 id="noticias-titulo">ГғЕЎltimas notГғВӯcias</h2>
        </div>
        <a class="text-link" href="/noticias">Ver todas</a>
      </div>

      {noticiaDestaque ? (
        <div class:list={['news-layout', !temAvisos && 'news-layout--sem-avisos']}>
          <NoticiaCard post={noticiaDestaque} destaque />

          <div class="post-grid" aria-label="NotГғВӯcias recentes">
            {noticiasGrade.map((post) => <NoticiaCard post={post} />)}
          </div>

          {temAvisos && (
            <aside class="notice-panel" aria-labelledby="avisos-titulo">
              <div class="notice-panel__header">
                <h3 id="avisos-titulo">Avisos</h3>
              </div>
              <ul class="notice-list">
                {avisosRapidos.map((aviso) => (
                  <li>
                    <time datetime={aviso.data_inicio}>{formatarDiaMes(aviso.data_inicio)}</time>
                    {aviso.link ? (
                      <a href={aviso.link}>{aviso.titulo}</a>
                    ) : (
                      <span>{aviso.titulo}</span>
                    )}
                  </li>
                ))}
              </ul>
            </aside>
          )}
        </div>
      ) : (
        <p class="vazio">
          As notГғВӯcias aparecem aqui assim que forem publicadas no painel. Publique a primeira em
          ГўвӮ¬Е“NotГғВӯcias do blogГўвӮ¬Вқ.
        </p>
      )}
    </div>
  </section>

  <section id="servicos" class="section section--cinza reveal" aria-labelledby="servicos-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">ServiГғВ§os para a categoria</p>
          <h2 id="servicos-titulo">Acesso rГғВЎpido</h2>
        </div>
      </div>
      <div class="quick-grid">
        <a class="quick-card quick-card--aco" href="/beneficios">
          <span class="quick-card__icone">BEN</span>
          <strong>BenefГғВӯcios</strong>
          <small>ConvГғВӘnios, descontos e vantagens negociadas para associados e dependentes.</small>
        </a>
        {globais.modulo_juridico_ativo !== false && (
          <a class="quick-card quick-card--vermelho" href="/juridico">
            <span class="quick-card__icone">JUR</span>
            <strong>Atendimento jurГғВӯdico</strong>
            <small>OrientaГғВ§ГғВЈo sobre direitos trabalhistas, rescisГғВөes, acordos e dГғВәvidas da categoria.</small>
          </a>
        )}
        <a class="quick-card" href="/filie-se">
          <span class="quick-card__icone">SIM</span>
          <strong>Filie-se</strong>
          <small>FortaleГғВ§a o sindicato e tenha acesso a serviГғВ§os exclusivos.</small>
        </a>
        <a class="quick-card" href="/contato">
          <span class="quick-card__icone">FALE</span>
          <strong>Fale conosco</strong>
          <small>Envie sua dГғВәvida ou solicite atendimento pelo canal oficial do sindicato.</small>
        </a>
      </div>
    </div>
  </section>

  <Estudio />

  <VitrineSocial />

  <section class="cta-band" aria-labelledby="cta-titulo">
    <div class="container cta-band__inner">
      <div>
        <p class="rotulo">FortaleГғВ§a sua representaГғВ§ГғВЈo</p>
        <h2 id="cta-titulo">Filie-se ao sindicato e acompanhe tudo em primeira mГғВЈo.</h2>
      </div>
      <a class="button" href="/filie-se">Quero me filiar</a>
    </div>
  </section>
</Base>
