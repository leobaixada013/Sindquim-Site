---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import Estudio from '../components/Estudio.astro';
import {
  getAvisoUrgente,
  getAvisosRapidos,
  getCardsInstagram,
  getConfiguracoes,
  getPostBanner,
  getPosts,
  urlImagem,
} from '../lib/directus';
import { formatarData, formatarDiaMes } from '../lib/formatar';

const [banner, todosPosts, cards, config, avisoUrgente, avisosRapidos] = await Promise.all([
  getPostBanner(),
  getPosts(6),
  getCardsInstagram(4),
  getConfiguracoes(),
  getAvisoUrgente(),
  getAvisosRapidos(4),
]);

const postsSemBanner = todosPosts.filter((post) => post.id !== banner?.id);
const noticiaDestaque = postsSemBanner[0] ?? null;
const noticiasGrade = postsSemBanner.slice(1, 4);
const temAvisos = avisosRapidos.length > 0;
const imagemBanner = banner ? urlImagem(banner.imagem, { largura: 1600, altura: 900 }) : null;
---

<Base imagemOg={imagemBanner}>
  {avisoUrgente && (
    <aside class="alert-strip" aria-label="Aviso urgente">
      <div class="container alert-strip__inner">
        <strong>{avisoUrgente.titulo}</strong>
        {avisoUrgente.mensagem_curta && <span>{avisoUrgente.mensagem_curta}</span>}
        {avisoUrgente.link && (
          <a href={avisoUrgente.link}>{avisoUrgente.texto_link ?? 'Saiba mais'}</a>
        )}
      </div>
    </aside>
  )}

  <section class="hero" aria-labelledby="hero-titulo">
    <div class="hero__media" style={imagemBanner ? `background-image:url('${imagemBanner}')` : undefined} aria-hidden="true"></div>
    {banner?.fixado_banner && <span class="carimbo" aria-hidden="true">Fixado pela diretoria</span>}
    <div class="container hero__content">
      <div class="hero__copy">
        {banner ? (
          <>
            <div class="hero__meta">
              {banner.categoria && <strong>{banner.categoria.nome}</strong>}
              <time datetime={banner.date_created}>{formatarData(banner.date_created)}</time>
            </div>
            <h1 id="hero-titulo">{banner.titulo}</h1>
            {banner.resumo && <p class="hero__resumo">{banner.resumo}</p>}
            <div class="hero__actions">
              <a class="button button--primario" href={`/noticias/${banner.slug}`}>Ler matéria completa</a>
              <a class="button button--fantasma" href="/noticias">Todas as notícias</a>
            </div>
          </>
        ) : (
          <>
            <p class="rotulo rotulo--claro">Informação oficial</p>
            <h1 id="hero-titulo">Nosso trabalho tem valor. Nossos direitos não são negociáveis.</h1>
            <p class="hero__resumo">
              Notícias, mobilização e atendimento para fortalecer a categoria em cada negociação.
            </p>
            <div class="hero__actions">
              <a class="button button--primario" href="/noticias">Ver notícias</a>
              <a class="button button--fantasma" href="/filie-se">Filie-se</a>
            </div>
          </>
        )}
      </div>
    </div>
  </section>


  <section id="noticias" class="section reveal" aria-labelledby="noticias-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">Boletim da categoria</p>
          <h2 id="noticias-titulo">Últimas notícias</h2>
        </div>
        <a class="text-link" href="/noticias">Ver todas</a>
      </div>

      {noticiaDestaque ? (
        <div class:list={['news-layout', !temAvisos && 'news-layout--sem-avisos']}>
          <PostCard post={noticiaDestaque} destaque />

          <div class="post-grid" aria-label="Notícias recentes">
            {noticiasGrade.map((post) => <PostCard post={post} />)}
          </div>

          {temAvisos && (
            <aside class="notice-panel" aria-labelledby="avisos-titulo">
              <div class="notice-panel__header">
                <h3 id="avisos-titulo">Avisos</h3>
              </div>
              <ul class="notice-list">
                {avisosRapidos.map((aviso) => (
                  <li>
                    <time datetime={aviso.data_inicio}>{formatarDiaMes(aviso.data_inicio)}</time>
                    {aviso.link ? (
                      <a href={aviso.link}>{aviso.titulo}</a>
                    ) : (
                      <span>{aviso.titulo}</span>
                    )}
                  </li>
                ))}
              </ul>
            </aside>
          )}
        </div>
      ) : (
        <p class="vazio">
          As notícias aparecem aqui assim que forem publicadas no painel. Publique a primeira em
          “Notícias do blog”.
        </p>
      )}
    </div>
  </section>

  <section id="servicos" class="section section--cinza reveal" aria-labelledby="servicos-titulo">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="rotulo">Serviços para a categoria</p>
          <h2 id="servicos-titulo">Acesso rápido</h2>
        </div>
      </div>
      <div class="quick-grid">
        <a class="quick-card quick-card--aco" href="/beneficios">
          <span class="quick-card__icone">BEN</span>
          <strong>Benefícios</strong>
          <small>Convênios, descontos e vantagens negociadas para associados e dependentes.</small>
        </a>
        <a class="quick-card quick-card--vermelho" href="/juridico">
          <span class="quick-card__icone">JUR</span>
          <strong>Atendimento jurídico</strong>
          <small>Orientação sobre direitos trabalhistas, rescisões, acordos e dúvidas da categoria.</small>
        </a>
        <a class="quick-card" href="/filie-se">
          <span class="quick-card__icone">SIM</span>
          <strong>Filie-se</strong>
          <small>Fortaleça o sindicato e tenha acesso a serviços exclusivos.</small>
        </a>
        <a class="quick-card" href="/contato">
          <span class="quick-card__icone">FALE</span>
          <strong>Fale conosco</strong>
          <small>Envie sua dúvida ou solicite atendimento pelo canal oficial do sindicato.</small>
        </a>
      </div>
    </div>
  </section>

  <Estudio />

  {(cards.length > 0 || config?.instagram_url) && (
    <section class="section section--reels reveal" aria-labelledby="instagram-titulo">
      <div class="container">
        <div class="section-heading reels-heading">
          <div>
            <p class="rotulo">Reels do sindicato</p>
            <h2 id="instagram-titulo">Cortes rápidos do Reação Química em Debate</h2>
            <p class="reels-heading__texto">
              Trechos curtos, bastidores e chamadas para acompanhar a discussão onde a categoria já está: no celular.
            </p>
          </div>
          {config?.instagram_url && (
            <a class="button button--tinta" href={config.instagram_url} target="_blank" rel="noopener">
              Ver Reels no Instagram
            </a>
          )}
        </div>
        {cards.length > 0 ? (
          <div class="reels-grid" aria-label="Reels recentes do Instagram">
            {cards.map((card, indice) =>
              card.link ? (
                <a class:list={['reel-card', indice === 0 && 'reel-card--destaque']} href={card.link} target="_blank" rel="noopener">
                  {card.imagem && (
                    <img src={urlImagem(card.imagem, { largura: indice === 0 ? 720 : 480, altura: indice === 0 ? 1280 : 854 })} alt="" loading={indice === 0 ? 'eager' : 'lazy'} decoding="async" />
                  )}
                  <span class="reel-card__play" aria-hidden="true">▶</span>
                  <span class="reel-card__badge">{indice === 0 ? 'Reel em destaque' : 'Reel'}</span>
                  <span class="reel-card__legenda">{card.legenda ?? 'Assistir Reel'}</span>
                  <span class="reel-card__acao">Abrir no Instagram</span>
                </a>
              ) : (
                <article class:list={['reel-card', indice === 0 && 'reel-card--destaque']}>
                  {card.imagem && (
                    <img src={urlImagem(card.imagem, { largura: indice === 0 ? 720 : 480, altura: indice === 0 ? 1280 : 854 })} alt="" loading={indice === 0 ? 'eager' : 'lazy'} decoding="async" />
                  )}
                  <span class="reel-card__play" aria-hidden="true">▶</span>
                  <span class="reel-card__badge">{indice === 0 ? 'Reel em destaque' : 'Reel'}</span>
                  <span class="reel-card__legenda">{card.legenda ?? 'Reel do sindicato'}</span>
                </article>
              ),
            )}
          </div>
        ) : (
          <p>
            Os Reels cadastrados no painel aparecem aqui. Enquanto isso, acompanhe o perfil:{' '}
            <a class="text-link" href={config?.instagram_url} target="_blank" rel="noopener">ver Instagram</a>.
          </p>
        )}
      </div>
    </section>
  )}

  <section class="cta-band" aria-labelledby="cta-titulo">
    <div class="container cta-band__inner">
      <div>
        <p class="rotulo">Fortaleça sua representação</p>
        <h2 id="cta-titulo">Filie-se ao sindicato e acompanhe tudo em primeira mão.</h2>
      </div>
      <a class="button" href="/filie-se">Quero me filiar</a>
    </div>
  </section>
</Base>
