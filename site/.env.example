# URL do Directus vista pelo servidor Astro (na rede interna do Docker: http://directus:8055)
DIRECTUS_URL=http://localhost:8055

# URL pública do Directus, usada para montar os links de imagem no HTML
# (em produção: https://painel.seudominio.com.br)
PUBLIC_DIRECTUS_URL=http://localhost:8055

# URL pública do site (usada em canonical, sitemap, RSS)
PUBLIC_SITE_URL=http://localhost:4321
